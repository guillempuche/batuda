# Local Postgres (docker compose)
DATABASE_URL=postgresql://engranatge:engranatge@localhost:5433/engranatge

# NeonDB (production)
# DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/forja?sslmode=require

# Better Auth
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=change-me-in-production
BETTER_AUTH_BASE_URL=https://api.engranatge.localhost
BETTER_AUTH_INSECURE_COOKIES=false
ALLOWED_ORIGINS=https://*.engranatge.localhost

# Email provider (vendor-neutral surface; AgentMail for real send, local-inbox for dev catcher)
EMAIL_API_KEY=am_...
EMAIL_WEBHOOK_SECRET=whsec_...
# EMAIL_PROVIDER picks the runtime layer. **Required, no default** — the developer
# must explicitly choose so local config never silently leaks into prod (or vice versa).
# Allowed values: local-inbox | agentmail
# Local dev should use local-inbox (writes messages to apps/server/.dev-inbox/*.md,
# never hits the network). Use agentmail in prod, or temporarily in dev for an
# integration sanity check against the real API.
EMAIL_PROVIDER=local-inbox

# Object storage (S3-compatible — MinIO local, Cloudflare R2 in prod)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=engranatge
STORAGE_SECRET_ACCESS_KEY=engranatge-secret
STORAGE_BUCKET=engranatge-recordings

# Production example:
# STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY_ID=...
# STORAGE_SECRET_ACCESS_KEY=...
# STORAGE_BUCKET=engranatge-recordings

# Transcription provider (speech-to-text)
TRANSCRIPTION_API_KEY=

# ── Research capability providers (§18 of docs/backend-research.md) ──
# Each is required, no auto/fallback. Boot fails if unset.
# Local dev defaults to stub (zero cost, deterministic fake data).
RESEARCH_SEARCH_PROVIDER=stub
RESEARCH_SCRAPE_PROVIDER=stub
RESEARCH_EXTRACT_PROVIDER=stub
RESEARCH_DISCOVER_PROVIDER=stub
RESEARCH_REGISTRY_PROVIDER_ES=stub
RESEARCH_REPORT_PROVIDER_ES=stub

# ── Research budgets & concurrency ─────────────────────────────────────
RESEARCH_DEFAULT_BUDGET_CENTS=100
RESEARCH_DEFAULT_PAID_BUDGET_CENTS=500
RESEARCH_DEFAULT_AUTO_APPROVE_PAID_CENTS=200
RESEARCH_DEFAULT_PAID_MONTHLY_CAP_CENTS=2000
RESEARCH_MONTHLY_CAP_HARD_CEILING_CENTS=10000
RESEARCH_MAX_CONCURRENT_FIBERS_PER_USER=3
RESEARCH_MAX_CONCURRENCY_FANOUT=3
RESEARCH_CONFIRM_THRESHOLD_FANOUT=10

# Provider API keys (only needed for the selected providers above)
# FIRECRAWL_API_KEY=fc-...
# BRAVE_SEARCH_API_KEY=BSA...
# EINFORMA_API_KEY=...

# ── Research LLM inference (for agent loop) ────────────────────────────
# stub = deterministic fake output, zero cost. For real LLM locally,
# use groq with a free-tier key and qwen/qwen3-32b.
RESEARCH_LLM_PROVIDER=stub
# RESEARCH_LLM_MODEL=qwen/qwen3-32b
# RESEARCH_LLM_API_KEY=gsk_...
# RESEARCH_LLM_BASE_URL=

# Server
PORT=3010
NODE_ENV=development
MIN_LOG_LEVEL=Debug
