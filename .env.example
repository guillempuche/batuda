# Local Postgres (docker compose)
DATABASE_URL=postgresql://batuda:batuda@localhost:5433/batuda

# NeonDB (production)
# DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/batuda?sslmode=require

# Better Auth
# Local-dev default below. To regenerate, run inside the Nix flake shell
# (`nix develop` or direnv-auto) — works the same on macOS, Linux, and
# Windows (WSL), since the flake provides Node 24:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET=IhBhBsh9TVz/zni+w+UeMaFEw6njkbO6VfWRYF4JxGI=
BETTER_AUTH_BASE_URL=https://api.batuda.localhost
BETTER_AUTH_INSECURE_COOKIES=false
# Required in every env (no code default). `loose` widens the per-IP rate limit
# on /sign-in/email so the e2e suite (and dense local sign-in cycles) don't trip
# Better Auth's brute-force gate; prod must set `strict`.
BETTER_AUTH_RATE_LIMIT=loose
# OAuth access-token lifetime in seconds. Required. Long here (1 day) so connected
# MCP clients don't re-authorize mid-session while developing; prod sets it short.
OAUTH_ACCESS_TOKEN_TTL_SECONDS=86400
# Days before an OAuth client with no consent is garbage-collected. Required. Long
# here so a client registered while testing isn't swept; prod sets it short.
OAUTH_CLIENT_GC_DAYS=365
# Per-key rate limit for org-scoped API keys (what AI/MCP clients call /mcp with).
# All three required. Disabled here so local MCP testing (many tool calls per turn)
# isn't throttled; prod enables it. MAX requests per WINDOW_SECONDS.
API_KEY_RATE_LIMIT_ENABLED=false
API_KEY_RATE_LIMIT_MAX=600
API_KEY_RATE_LIMIT_WINDOW_SECONDS=60
# The literal trusts the main dev origin; the `*.batuda.localhost` wildcard
# trusts each git worktree's auto-prefixed origin (`<branch>.batuda.localhost`)
# so a worktree dev stack works with no per-worktree edits. Wildcards are
# accepted only under `.localhost` (real-domain wildcards are rejected at boot).
ALLOWED_ORIGINS=https://batuda.localhost,https://*.batuda.localhost
# Canonical public app origin for the links the server mints (invitations).
# Must be one of ALLOWED_ORIGINS — boot fails otherwise.
APP_PUBLIC_URL=https://batuda.localhost

# Optional feature toggles — leave unset (empty = off / fallback):
#   PORTLESS_URL — dev tunnel base URL surfaced in logs; falls back to localhost:PORT
#   OTEL_EXPORTER_OTLP_ENDPOINT / OTEL_EXPORTER_OTLP_HEADERS — telemetry export, off when empty

# CRM email provider. **Required, no default** — the developer must
# explicitly choose. Allowed values: local-inbox.
# Local dev uses local-inbox (writes messages to apps/server/.dev-inbox/*.md,
# never hits the network). Real outbound SMTP / inbound IMAP transport ships
# in the mail-worker slice.
EMAIL_PROVIDER=local-inbox

# System transactional email (magic links, password resets, future
# invitations). **Required, no default**. Allowed values: local | resend.
# Local dev uses `local` (writes the magic-link to apps/server/.dev-inbox/
# with `labels: magic-link`). Cloud deployments use `resend`, which calls
# Resend's REST API; in that case `EMAIL_API_KEY_TRANSACTIONAL` and
# `EMAIL_FROM_TRANSACTIONAL` are also required.
EMAIL_PROVIDER_TRANSACTIONAL=local
# EMAIL_API_KEY_TRANSACTIONAL=re_...
# EMAIL_FROM_TRANSACTIONAL=Batuda <noreply@batuda.co>

# AES-256-GCM master key for encrypting per-inbox IMAP/SMTP credentials at
# rest. Base64-encoded 32 bytes. Per-inbox subkeys are derived via
# HKDF-SHA256 (inbox id as info), so a single row leak doesn't cascade.
# Required, no default — boot fails rather than ship plaintext.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
EMAIL_CREDENTIAL_KEY=Vt2vKJZS3l6vDmvqEnt5uVmjFPMbWnBOSRiXZWJqwYU=

# Inbox health probe interval. Walks active inboxes, calls IMAP+SMTP probe,
# updates inboxes.grant_status. Default 900s (15 min); set lower in dev to
# verify connect_failed transitions live.
EMAIL_HEALTH_PROBE_INTERVAL_SEC=900

# Mail-worker tunables (apps/mail-worker/src/env.ts). All optional —
# defaults work for dev. Surfaced here so a tuner doesn't have to grep.
# - MAX_CONNECTIONS: per-replica IMAP IDLE cap; sharding across replicas
#   uses pg_advisory_lock per inbox so this is a hard ceiling per process.
# - BACKFILL_DAYS: initial fetch horizon when a brand-new inbox connects
#   (or after a uidvalidity drift). 30 covers "yesterday's thread"
#   without paying for years of history on first sync.
# - IDLE_TIMEOUT_SEC: how often the worker re-syncs each folder. New mail can
#   also wake it sooner via the IMAP `exists` event, but this poll is the
#   reliable floor (not every server/catcher pushes IDLE reliably). RFC 2177
#   caps IDLE at 30 min; the code default is 1740s (29 min). Dev uses a short
#   interval so locally-injected mail ingests promptly.
# EMAIL_WORKER_MAX_CONNECTIONS=50
# EMAIL_WORKER_BACKFILL_DAYS=30
EMAIL_WORKER_IDLE_TIMEOUT_SEC=15

# Local SMTP+IMAP catcher (GreenMail). The CLI (db reset / doctor / services)
# polls this REST endpoint. The docker-compose host ports (1025/1143/8025) are
# fixed; override the URL only if a host process already binds 8025.
MAIL_CATCHER_HTTP_URL=http://localhost:8025

# Geocoder (address → lat/lng for the Where panel). Required, no default.
# nominatim is free via https://nominatim.openstreetmap.org — single server-side
# rate-limit of 1 req/sec enforced by a Semaphore. Attribution: © OpenStreetMap.
GEOCODER_PROVIDER=nominatim

# Calendar provider (vendor-neutral surface; cal.com for real bookings, stub for dev).
# Required, no default — boot fails on unset / unknown values.
# Allowed values: stub | calcom
# Local dev should use stub (zero cost, deterministic fake data).
CALENDAR_PROVIDER=stub

# Shared secret cal.com uses to sign webhook bodies (HMAC-SHA256, hex
# digest in `x-cal-signature-256`). Optional at boot — the webhook
# handler returns 503 on every request until this lands. Naming follows
# AGENTS.md: <DOMAIN>=CALENDAR, <ROLE>=WEBHOOK_SECRET.
CALENDAR_WEBHOOK_SECRET=

# Object storage (S3-compatible — MinIO local, Cloudflare R2 in prod)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_ACCESS_KEY_ID=batuda
STORAGE_SECRET_ACCESS_KEY=batuda-secret
STORAGE_BUCKET=batuda-assets

# Production example:
# STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY_ID=...
# STORAGE_SECRET_ACCESS_KEY=...
# STORAGE_BUCKET=batuda-assets

# Transcription provider (speech-to-text)
TRANSCRIPTION_API_KEY=

# ── Research providers (§18 of docs/backend-research.md) ─────────────
# Role-first, vendor-neutral. Comma-list accepted: first value = primary,
# rest = fallback order on ProviderError. Registry/report are per-country
# (ISO-3166-1 alpha-2 suffix). Boot fails on unset / unknown vendors.
# Local dev defaults to stub (zero cost, deterministic fake data).
RESEARCH_PROVIDER_SEARCH=stub
RESEARCH_PROVIDER_SCRAPE=stub
RESEARCH_PROVIDER_EXTRACT=stub
RESEARCH_PROVIDER_DISCOVER=stub
RESEARCH_PROVIDER_REGISTRY_ES=stub
RESEARCH_PROVIDER_REPORT_ES=stub

# API keys for search/scrape/extract/discover/registry/report. If one vendor
# covers multiple capabilities (e.g. Firecrawl for scrape + extract +
# discover), paste the same value in each var. Slot 1 = unsuffixed; slot N =
# `_2`, `_3`, … — only needed when the corresponding _PROVIDER_ list has ≥2
# entries.
# RESEARCH_API_KEY_SEARCH=BSA...
# RESEARCH_API_KEY_SCRAPE=fc-...
# RESEARCH_API_KEY_EXTRACT=fc-...
# RESEARCH_API_KEY_REGISTRY_ES=AccessId:AccessKey   # LibreBOR Basic-auth pair, when REGISTRY_ES=librebor
# RESEARCH_API_KEY_REPORT_ES=
# RESEARCH_API_KEY_SEARCH_2=

# ── Research LLM tiers (Agent / Extract / Writer) ────────────────────
# Each tier is a separate LanguageModel service so the research fiber can
# pin a different model to each phase (reasoning / structured / prose).
# Vendors: stub | together | fireworks | nebius | groq | novita | sambanova | custom
RESEARCH_LLM_AGENT_PROVIDERS=stub
RESEARCH_LLM_EXTRACT_PROVIDERS=stub
RESEARCH_LLM_WRITER_PROVIDERS=stub
# RESEARCH_LLM_AGENT_MODEL=Qwen/Qwen3.5-397B-A17B
# RESEARCH_LLM_AGENT_API_KEY=
# RESEARCH_LLM_AGENT_API_KEY_2=
# RESEARCH_LLM_EXTRACT_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# RESEARCH_LLM_EXTRACT_API_KEY=
# RESEARCH_LLM_WRITER_MODEL=Qwen/Qwen3-14B
# RESEARCH_LLM_WRITER_API_KEY=

# ── Opt into REAL providers for a local run ──────────────────────────
# Keep this commented here; paste real values only in your gitignored
# `.env`, never in this file. Use a low-cap DEV key per vendor.
# LLM via Nebius through the `custom` vendor so the base URL is explicit
# (Nebius moved AI Studio → Token Factory; set whichever OpenAI-compatible
# URL your account shows). Repeat the four lines for EXTRACT and WRITER.
# RESEARCH_LLM_AGENT_PROVIDERS=custom
# RESEARCH_LLM_AGENT_BASE_URL=https://api.tokenfactory.nebius.com/v1
# RESEARCH_LLM_AGENT_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# RESEARCH_LLM_AGENT_API_KEY=...dev-key...
# RESEARCH_PROVIDER_SEARCH=brave
# RESEARCH_API_KEY_SEARCH=BSA...
# RESEARCH_PROVIDER_SCRAPE=firecrawl
# RESEARCH_API_KEY_SCRAPE=fc-...
# RESEARCH_PROVIDER_EXTRACT=firecrawl
# RESEARCH_API_KEY_EXTRACT=fc-...
# RESEARCH_PROVIDER_REGISTRY_ES=librebor
# RESEARCH_PROVIDER_REPORT_ES=none

# ── Research budgets & concurrency ─────────────────────────────────────
RESEARCH_DEFAULT_BUDGET_CENTS=100
RESEARCH_DEFAULT_PAID_BUDGET_CENTS=500
RESEARCH_DEFAULT_AUTO_APPROVE_PAID_CENTS=200
RESEARCH_DEFAULT_PAID_MONTHLY_CAP_CENTS=2000
RESEARCH_MONTHLY_CAP_HARD_CEILING_CENTS=10000
RESEARCH_MAX_CONCURRENT_FIBERS_TOTAL=3
RESEARCH_MAX_CONCURRENCY_FANOUT=3
RESEARCH_CONFIRM_THRESHOLD_FANOUT=10

# Server
PORT=3010
NODE_ENV=development
MIN_LOG_LEVEL=Debug

# ── OpenTelemetry (traces + logs + metrics via OTLP/HTTP JSON) ────────
# Points at the local otel-tui receiver (started with `pnpm dev:otel`,
# provided by the Nix flake). When otel-tui isn't running the exporter
# logs a connection error each tick — harmless, but stop the server or
# unset this var if the noise bothers you.
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Production example (Honeycomb / Grafana / etc):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_KEY
