{
	"name": "@engranatge/ui",
	"version": "2026.4.19",
	"type": "module",
	"types": "./src/index.ts",
	"main": "./src/index.ts",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		},
		"./blocks": {
			"types": "./src/blocks/index.ts",
			"import": "./src/blocks/index.ts"
		},
		"./pri": {
			"types": "./src/pri/index.ts",
			"import": "./src/pri/index.ts"
		},
		"./tokens.css": "./src/tokens.css",
		"./tailwind.css": "./src/tailwind.css"
	},
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "1.3.0",
		"@tiptap/core": "^3.22.3",
		"@tiptap/pm": "^3.22.3",
		"effect": "4.0.0-beta.43",
		"styled-components": "6.3.12"
	},
	"peerDependencies": {
		"react": "^19",
		"react-dom": "^19",
		"tailwindcss": ">=4"
	},
	"devDependencies": {
		"@types/react": "19.2.14",
		"tailwindcss": ">=4",
		"tsdown": "^0.21.7",
		"typescript": "^5.9.3"
	},
	"private": false,
	"files": [
		"dist"
	],
	"publishConfig": {
