{
	"name": "@batuda/ui",
	"version": "2026.4.21-2",
	"type": "module",
	"types": "./dist/index.d.mts",
	"main": "./dist/index.mjs",
	"exports": {
		".": {
			"development": "./src/index.ts",
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs"
		},
		"./blocks": {
			"development": "./src/blocks/index.ts",
			"types": "./dist/blocks/index.d.mts",
			"import": "./dist/blocks/index.mjs"
		},
		"./pri": {
			"development": "./src/pri/index.ts",
			"types": "./dist/pri/index.d.mts",
			"import": "./dist/pri/index.mjs"
		},
		"./tokens.css": {
			"development": "./src/tokens.css",
			"default": "./dist/tokens.css"
		},
		"./tailwind.css": {
			"development": "./src/tailwind.css",
			"default": "./dist/tailwind.css"
		}
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "1.3.0",
		"@tiptap/core": "^3.22.3",
		"@tiptap/pm": "^3.22.3",
		"effect": "4.0.0-beta.43",
		"styled-components": "6.3.12"
	},
	"peerDependencies": {
		"react": "^19",
		"react-dom": "^19",
		"tailwindcss": ">=4"
	},
	"devDependencies": {
		"@types/react": "19.2.14",
		"tailwindcss": ">=4",
		"tsdown": "^0.21.7",
		"typescript": "^5.9.3"
	},
	"private": false,
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	}
}
