{
	"mcpServers": {
		"batuda": {
			"type": "http",
			"url": "https://api.batuda.co/mcp",
			"headers": {
				"x-api-key": "${BATUDA_API_KEY}"
			}
		},
		"cloudflare-api": {
			"type": "http",
			"url": "https://mcp.cloudflare.com/mcp"
		},
		"neon": {
			"command": "sh",
			"args": [
				"-c",
				"exec npx -y @neondatabase/mcp-server-neon start \"$NEON_API_KEY\""
			]
		}
	}
}
