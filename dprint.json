{
	"markdown": {
		"textWrap": "maintain",
		"emphasisKind": "asterisks",
		"strongKind": "asterisks",
		"newLineKind": "lf"
	},
	"includes": ["**/*.md"],
	"excludes": [
		"node_modules",
		"dist",
		".output",
		".wrangler",
		".cache",
		".turbo",
		"coverage",
		"docs/repos",
		"**/CHANGELOG.md"
	],
	"plugins": ["https://plugins.dprint.dev/markdown-0.21.1.wasm"]
}
