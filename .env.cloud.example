# ============================================================================
# Cloud environment — local operator use only
# ============================================================================
#
# Loaded by `pnpm cli --env cloud ...` commands to target the cloud DB/auth.
# NOT read by GitHub Actions (CI uses its own secrets — see .env.example.github).
#
# To use:
#   1. Copy this file to .env.cloud (or run `pnpm cli setup`)
#   2. Fill in the values from your production secrets vault
#   3. Run `pnpm cli --env cloud doctor` to verify reachability + host shape
#
# ⚠  Every destructive op with `--env cloud` requires re-typing the DB
#    hostname, and every run is appended to ./cloud-audit.log (gitignored).
# ============================================================================


# ── Database ────────────────────────────────────────────────────────────────
# NeonDB connection string. The hostname here is what `confirm-cloud` will
# prompt you to re-type on every write op.
DATABASE_URL=postgres://user:pass@ep-xxx.aws.neon.tech/batuda?sslmode=require


# ── Better Auth ─────────────────────────────────────────────────────────────
# Must be at least 32 chars. Generate with:
#   node -e "console.log(crypto.randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=

# Public base URL where the server serves /auth/*. Must be https:// for cloud.
BETTER_AUTH_BASE_URL=https://api.batuda.co

# Comma-separated list of allowed origins for CORS.
ALLOWED_ORIGINS=https://batuda.co,https://engranatge.com


# ── Email (BYO mailbox: IMAP + SMTP per inbox) ──────────────────────────────
# `local-inbox` is currently the only option (writes apps/server/.dev-inbox/*.md
# and never hits the network). Real outbound SMTP / inbound IMAP transport
# ships in the mail-worker slice; this var stays so its shape is stable.
EMAIL_PROVIDER=local-inbox
# AES-256-GCM master key for encrypting per-inbox IMAP/SMTP credentials at
# rest. Base64-encoded 32 bytes. Boot fails rather than ship plaintext.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('base64'))"
EMAIL_CREDENTIAL_KEY=


# ── Storage (Cloudflare R2) ─────────────────────────────────────────────────
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
STORAGE_REGION=auto
STORAGE_BUCKET=batuda-assets
