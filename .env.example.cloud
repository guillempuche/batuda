# ============================================================================
# CLI cloud target — secrets only
# ============================================================================
#
# Loaded by `pnpm cli --env cloud ...` to target the live cloud resources
# (NeonDB, R2, Cal.com). Copy to `.env.cloud` (gitignored) and fill the
# values from GitHub → Settings → Environments → production → Secrets.
#
# Only GitHub *Secrets* belong here — GitHub will never let them be read
# back from the API, so they must live locally. Non-secret *Variables*
# (BETTER_AUTH_BASE_URL, STORAGE_ENDPOINT/REGION/BUCKET, …) are fetched
# automatically from the `production` env via `gh variable list` at CLI
# startup (see apps/cli/src/lib/load-env.ts → fetchGhVariables). If `gh`
# is missing, unauthed, or offline, the CLI prints a hint and falls back
# to whatever is in this file; any still-missing required var will fail
# loudly at the specific Config read site.
#
# Never share the resulting `.env.cloud`: it carries prod credentials.
# Provenance: `.env.example.github` is the canonical source for what gets
# stored in GitHub. Bump this file when a new *secret* lands there that
# the CLI also consumes.
# ============================================================================


# ── NeonDB ──────────────────────────────────────────────────────────────────
# Pooled URL works for most CLI commands; `pnpm cli db migrate` wants the
# direct (non-pooled) URL because the pooler rejects long-running DDL.
# `confirm-cloud` will prompt you to re-type the hostname before any
# destructive op.
DATABASE_URL=postgres://...


# ── Better Auth signing key ─────────────────────────────────────────────────
# Must byte-match the GitHub Secret of the same name (the prod server signs
# session tokens with it; mismatched CLI key invalidates real sessions).
BETTER_AUTH_SECRET=


# ── Inbox credential decryption (AES-256-GCM, base64 32 bytes) ──────────────
# Must byte-match the server/mail-worker value, or `pnpm cli email *`
# commands fail to decrypt per-inbox IMAP/SMTP creds.
EMAIL_CREDENTIAL_KEY=


# ── Cloudflare R2 credentials ───────────────────────────────────────────────
# Endpoint, region, and bucket come from the GH variable fetch — only the
# access keys (secrets) live here.
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=


# ── Cal.com ─────────────────────────────────────────────────────────────────
# CALENDAR_API_KEY authenticates admin REST calls; CALENDAR_WEBHOOK_SECRET
# verifies inbound /webhooks/calcom signatures when replaying events locally.
CALENDAR_API_KEY=cal_...
CALENDAR_WEBHOOK_SECRET=
