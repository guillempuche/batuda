{
	"name": "@engranatge/server",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "portless api.engranatge node --watch --env-file=../../.env --import tsx src/main.ts",
		"dev:mcp": "node --env-file=../../.env --import tsx src/mcp-stdio.ts",
		"build": "tsdown src/main.ts src/mcp-stdio.ts src/db/migrate.ts",
		"check-types": "tsc --noEmit",
		"start": "node dist/main.mjs",
		"migrate": "node --env-file=../../.env --import tsx src/db/migrate.ts"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1026.0",
		"@aws-sdk/s3-request-presigner": "^3.1026.0",
		"@better-auth/api-key": "^1.5.6",
		"@effect/platform-node": "4.0.0-beta.43",
		"@effect/sql-pg": "4.0.0-beta.43",
		"@engranatge/auth": "workspace:*",
		"@engranatge/controllers": "workspace:*",
		"@engranatge/domain": "workspace:*",
		"@engranatge/research": "workspace:*",
		"agentmail": "^0.4.18",
		"better-auth": "^1.5.6",
		"effect": "4.0.0-beta.43",
		"kysely": "^0.28.15",
		"pg": "^8.20.0",
		"svix": "^1.62.0"
	},
	"devDependencies": {
		"@types/node": "^22.15.0",
		"@types/pg": "^8.20.0",
		"tsdown": "^0.21.7",
		"tsx": "^4.20.3",
		"typescript": "^5.9.3"
	},
	"private": true
}
