  # paint on every visit, jarring for the auth-gated routes visitors
  # land on. Revisit when ready/health gating is in place.
  cloud.unikraft.v1.instances/scale_to_zero.policy: "off"
rootfs: ./Dockerfile
cmd: ["/usr/bin/node", "/app/.output/server/index.mjs"]
