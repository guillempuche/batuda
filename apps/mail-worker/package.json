{
	"name": "@batuda/mail-worker",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "node --watch --env-file=../../.env --import tsx src/main.ts",
		"build": "tsdown src/main.ts",
		"check-types": "tsc --noEmit",
		"start": "node dist/main.mjs",
		"test": "vitest run --passWithNoTests"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1026.0",
		"@batuda/controllers": "workspace:*",
		"@batuda/server": "workspace:*",
		"@effect/platform-node": "4.0.0-beta.43",
		"@effect/sql-pg": "4.0.0-beta.43",
		"effect": "4.0.0-beta.43",
		"imapflow": "^1.3.2",
		"mailparser": "^3.9.8",
		"pg": "^8.20.0"
	},
	"devDependencies": {
		"@types/mailparser": "^3.4.6",
		"@types/node": "^22.15.0",
		"@types/nodemailer": "^8.0.0",
		"@types/pg": "^8.20.0",
		"nodemailer": "^8.0.7",
		"tsdown": "^0.21.7",
		"tsx": "^4.20.3",
		"typescript": "^5.9.3",
		"vitest": "^4.1.4"
	},
	"private": true
}
