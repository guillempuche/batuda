{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"types": ["vite/client"],
		"baseUrl": ".",
		"paths": {
			"#/*": ["./src/*"]
		},
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"noEmit": true
	},
	"include": ["src", "vite.config.ts"],
	"exclude": ["node_modules", "dist", ".output"]
}
