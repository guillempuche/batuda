{
	"$schema": "https://v2-9-6.turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**/*"]
		},
		"check-deps": {
			"outputs": [],
			"cache": true
		},
		"check-types": {
			"dependsOn": ["^check-types"],
			"outputs": []
		},
		"lint": {
			"outputs": [],
			"cache": true
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"test": {
			"dependsOn": ["^build"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"src/**/*",
				"test/**/*",
				"**/*.test.*",
				"**/*.spec.*"
			],
			"outputs": ["coverage/**/*"],
			"cache": true
		}
	}
}
