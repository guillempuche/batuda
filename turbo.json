{
	"$schema": "https://v2-9-6.turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"env": ["VITE_*"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**/*"]
		},
		"check-deps": {
			"outputs": [],
			"cache": true
		},
		"check-types": {
			"dependsOn": ["^check-types"],
			"outputs": []
		},
		"lint": {
			"outputs": [],
			"cache": true
		},
		"dev": {
			"persistent": true,
			"cache": false
		},
		"test": {
			"dependsOn": ["^build"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"src/**/*",
				"test/**/*",
				"**/*.test.*",
				"**/*.spec.*"
			],
			"outputs": ["coverage/**/*"],
			"cache": true
		},
		"test:integration": {
			"dependsOn": ["^build"],
			"env": [
				"DATABASE_URL",
				"BETTER_AUTH_SECRET",
				"EMAIL_CREDENTIAL_KEY",
				"STORAGE_ENDPOINT",
				"STORAGE_REGION",
				"STORAGE_ACCESS_KEY_ID",
				"STORAGE_SECRET_ACCESS_KEY",
				"STORAGE_BUCKET"
			],
			"passThroughEnv": ["CI"],
			"inputs": [
				"$TURBO_DEFAULT$",
				"src/**/*",
				"**/*.integration.test.*",
				"../../scripts/integration-db-setup.ts"
			],
			"outputs": ["coverage/**/*"],
			"cache": true
		}
	}
}
