{
    "name": "motion-plus-workspace",
    "version": "0.0.0",
    "description": "The private repo for Motion+ sites, examples and packages",
    "private": true,
    "author": "Matt Perry",
    "main": "index.js",
    "workspaces": [
        "packages/*",
        "dev/*",
        "sites/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev",
        "test": "turbo run test",
        "test-e2e": "yarn playwright test",
        "version-plus": "lerna version --force-publish=motion-plus,motion-plus-dom",
        "new": "turbo run build && yarn test && yarn test-e2e && lerna publish from-package --yes && turbo run new-package && yarn notify-slack && node scripts/create-github-release.js && yarn push-to-site",
        "push-to-site": "yarn changelog && node scripts/push-to-site.js",
        "new-alpha": "turbo run build && lerna publish from-package --canary --preid alpha && turbo run new-package",
        "changelog": "node scripts/generate-changelog-csv.js",
        "notify-slack": "NODE_ENV=production node scripts/notify-slack.js",
        "test-notify-slack": "NODE_ENV=development node scripts/notify-slack.js"
    },
    "devDependencies": {
        "@playwright/test": "^1.48.0",
        "@rollup/plugin-node-resolve": "^15.3.0",
        "@rollup/plugin-replace": "^6.0.1",
        "@rollup/plugin-terser": "^0.4.4",
        "@types/jest": "^29.5.13",
        "@types/node": "^22.7.5",
        "baseline-browser-mapping": "^2.9.11",
        "bundlesize": "^0.18.2",
        "concurrently": "^9.1.0",
        "lerna": "^4.0.0",
        "prettier": "^2.5.1",
        "rollup": "^4.24.0",
        "rollup-plugin-dts": "^6.1.1",
        "rollup-plugin-preserve-directives": "^0.4.0",
        "turbo": "^2.1.3",
        "typescript": "^5.6.3",
        "wrangler": "^4.42.0"
    },
    "packageManager": "yarn@3.1.0",
    "dependencies": {
        "dotenv": "^17.2.3",
        "framer-api": "^0.1.1",
        "papaparse": "^5.5.3"
    }
}
